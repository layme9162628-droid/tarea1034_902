---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  img?: ImageMetadata;
  tags?: string[];
  href?: string;
}
const { title, description, img, tags = [], href = '#' } = Astro.props;
---
<article class="project-card">
  <div class="project-img">
    {img && <Image src={img} alt={title} width={720} height={405} format="webp" quality={70} loading="lazy" decoding="async" />}
  </div>
  <div class="project-body">
    <div class="project-title">{title}</div>
    <p class="project-desc">{description}</p>
    <div class="project-tags">
      {tags.map((t)=> <span>{t}</span>)}
    </div>
    <a class="project-link" href={href} target="_blank" rel="noopener noreferrer">Ver proyecto ↗</a>
  </div>
</article>
