---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { getImage } from '../utils/images';
---
<BaseLayout title="Proyecto 1">

  <style>
    :root {
      --clr-accent: #c8a96e;
      --clr-dim: rgba(255,255,255,0.75);
      --clr-bg: #0f1724;
      --clr-surface: rgba(255,255,255,0.05);
      --clr-border: rgba(255,255,255,0.1);
      --radius-card: 18px;
      --ff-body: 'DM Sans', system-ui, sans-serif;
      --ff-mono: 'DM Mono', 'Courier New', monospace;
    }

    .project-page * { box-sizing: border-box; }
    .project-page { font-family: var(--ff-body); background: linear-gradient(135deg, #111827 0%, #0a1220 100%); color: #fff; min-height: 100vh; position: relative; }
    .project-page a { color: inherit; text-decoration: none; }
    .project-page::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at top right, rgba(200,169,110,0.16), transparent 24%), radial-gradient(circle at left bottom, rgba(255,255,255,0.05), transparent 14%); pointer-events: none; }
    .project-inner { position: relative; z-index: 1; max-width: 960px; margin: 0 auto; padding: clamp(100px, 12vh, 140px) 24px 80px; }

    .section-label { display: inline-block; font-family: var(--ff-mono); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--clr-accent); border-bottom: 1px solid var(--clr-accent); padding-bottom: 4px; margin-bottom: 1.2rem; }
    h1 { font-size: clamp(2.8rem, 6vw, 4.3rem); line-height: 1.05; margin-bottom: 1rem; font-weight: 700; }
    h1 em { font-style: normal; color: transparent; -webkit-text-stroke: 1px var(--clr-accent); }
    .lead { max-width: 680px; font-size: 1.15rem; line-height: 1.8; color: var(--clr-dim); margin-bottom: 2rem; }

    .hero-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 2.5rem; }
    .hero-badge { display: inline-flex; align-items: center; gap: 8px; font-family: var(--ff-mono); font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 12px 16px; border-radius: 999px; background: var(--clr-surface); border: 1px solid var(--clr-border); }
    .btn-back { display: inline-flex; align-items: center; gap: 8px; font-family: var(--ff-mono); font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--clr-accent); border-bottom: 1px solid rgba(200,169,110,0.5); }

    .section-panel { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-card); padding: 32px; }
    .section-panel h2 { font-size: clamp(1.7rem, 3vw, 2rem); margin-bottom: 1rem; }
    .subdesc { color: var(--clr-dim); font-size: 0.95rem; line-height: 1.8; margin-bottom: 2rem; max-width: 700px; }
    .grid-2 { display: grid; gap: 24px; }
    @media (min-width: 780px) { .grid-2 { grid-template-columns: 1.3fr 0.7fr; } }
    .summary-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-card); padding: 24px; }
    .summary-card h3 { font-size: 0.85rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--clr-accent); margin-bottom: 16px; }
    .summary-card p { color: var(--clr-dim); line-height: 1.75; margin-bottom: 10px; }
    .pill-list { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px; }
    .pill { display: inline-flex; align-items: center; font-family: var(--ff-mono); font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 10px 14px; border-radius: 999px; color: #fff; background: rgba(200,169,110,0.12); border: 1px solid rgba(200,169,110,0.2); }

    /* ── GALERÍA ── */
    .gallery-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 32px;
    }
    .gallery-grid .foto-main { grid-column: 1 / -1; }
    .foto-slot {
      aspect-ratio: 16/9;
      border-radius: var(--radius-card);
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 10px;
      color: rgba(255,255,255,0.3);
      font-family: var(--ff-mono);
      font-size: 0.75rem;
      transition: border-color .2s, transform .2s;
    }
    .foto-slot:hover { border-color: var(--clr-accent); transform: scale(1.012); }
    .foto-slot .ficon { font-size: 2rem; opacity: .35; }
    /* Cuando tengas fotos reales reemplaza el contenido por:
       <img src="/img/proyecto1-a.jpg" alt="..." style="width:100%;height:100%;object-fit:cover;"> */

    /* ── DRIVE CTA ── */
    .drive-banner {
      margin-top: 40px;
      background: rgba(200,169,110,0.07);
      border: 1px solid rgba(200,169,110,0.25);
      border-radius: var(--radius-card);
      padding: 32px;
      display: flex;
      flex-wrap: wrap;
      gap: 24px;
      align-items: center;
      justify-content: space-between;
    }
    .drive-banner-text h3 {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .drive-banner-text p {
      font-size: 0.9rem;
      color: var(--clr-dim);
      max-width: 420px;
      line-height: 1.6;
    }
    .btn-drive {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--clr-accent);
      color: #0a1220;
      font-family: var(--ff-mono);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 14px 28px;
      border-radius: 999px;
      transition: opacity .2s, transform .15s;
      white-space: nowrap;
    }
    .btn-drive:hover { opacity: .85; transform: translateY(-2px); }
  </style>

  <div class="project-page">
    <div class="project-inner">
      <span class="section-label">ELECTROCARDIOFONO</span>
      <h1>Desarrollo de un Sistema para la Captura y
Procesamiento de<br><em>de Señales ECG</em></h1>
      <p class="lead">Se diseño un circuito electrocardiofono para la materia de electronica de pulsos con el fin de aplicar 
        los conocimiento de la materia en este
        proyecto final, ademas de eso se uso el diseño de amplificadores de instrumentacion para la amplificacion de 
        la señal del electrocardiograma, ademas de eso se implemento 
        un filtro pasa bajos para eliminar el ruido de la señal y un filtro pasa altos para eliminar el offset de la señal.
      </p>

      <div class="hero-badges">
        <span class="hero-badge">Amplificadores de instrumentacion</span>
        <span class="hero-badge">Diseño de Filtros</span>
        <span class="hero-badge">Prototipado</span>
        <span class="hero-badge">Biomedicina</span>
        <span class="hero-badge">Electrónica de pulsos</span>
      </div>

      <a href="/" class="btn-back">← Volver al inicio</a>

      <section class="section-panel" aria-label="Descripción del proyecto" style="margin-top: 60px;">
        <span class="section-label">Resumen</span>
        <h2>Circuito diseñado para capturar señales electrocardiofonos para su procesamiento y filtrado </h2>
        <p class="subdesc">
          Se priorizó la claridad en la adquisición de señales y la fidelidad del procesamiento analógico, asegurando un registro seguro, limpio y libre de ruido de la actividad eléctrica del corazón.
          El objetivo fue reducir la interferencia de la red eléctrica, amplificar con precisión el complejo QRS y convertir las señales cardíacas en salidas tanto visuales como audibles en tiempo real.
        </p>

        <div class="grid-2">
          <div>
            <p> Este proyecto abordó la necesidad de captar microvoltajes corporales mediante electrodos y procesarlos mediante hardware físico. La propuesta se concentró en un diseño electrónico modular con etapas independientes de instrumentación, pre-filtrado, ganancia y acondicionamiento acústico.
            </p>
            <p>
              El objetivo fue reducir la interferencia de la red eléctrica, amplificar con precisión el complejo QRS y convertir las señales cardíacas en salidas tanto visuales como audibles en tiempo real.
            </p>
          </div>
          <aside class="summary-card">
            <h3>Ficha del proyecto</h3>
            <p><strong>Materia:</strong> Electronica de Pulsos </p>
            <p><strong>Docente:</strong> Ing. Borja</p>
            <p><strong>Semestre:</strong> 7 to Semestre — 2024</p>
            <p><strong>Tipo:</strong> Proyecto final de asignatura</p>
          </aside>
        </div>

        <div class="pill-list">
          <span class="pill">Interfaz adaptable</span>
          <span class="pill">Componentes dedicados</span>
          <span class="pill">Diseño modular</span>
          <span class="pill">Procesamiento analógico</span>
          <span class="pill">Filtros activos</span>
        </div>
      </section>

      <section class="section-panel" aria-label="Resultados del proyecto" style="margin-top: 40px;">
        <span class="section-label">Resultados</span>
        <h2>Impacto directo en la adquisición y fidelidad de la señal</h2>
        <p class="subdesc">El hardware se diseñó para facilitar el diagnóstico primario, con un sistema de filtrado activo que remueve ruidos musculares e interferencias externas sin alterar la morfología de las ondas cardíacas (P, QRS, T).</p>

        <div class="grid-2">
          <article class="summary-card">
            <h3>Resultado</h3>
            <p>Eliminación crítica de los 60 Hz de la red eléctrica mediante el acoplamiento del filtro Twin-T Notch, garantizando una salida de audio nítida y oscilogramas estables durante las pruebas con electrodos.</p>
          </article>
          <article class="summary-card">
            <h3>Aprendizaje</h3>
            <p>Validación experimental de circuitos analógicos de alta ganancia, control del acoplamiento y ruido en modo común, y optimización en la respuesta en frecuencia de filtros en cascada aplicados a la medicina.</p>
          </article>
        </div>
      </section>

      <!-- ── GALERÍA ── -->
<section aria-label="Fotos del proyecto" style="margin-top: 40px;">
  <span class="section-label">Galería</span>
  <div class="gallery-grid">
    
    <div class="foto-slot foto-main">
      <Image src={getImage('proy21.jpeg')} alt="Circuito integrado del Electrocardiófono" width={960} height={640} format="webp" quality={72} loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;" />
    </div>
    
    <div class="foto-slot">
      <Image src={getImage('proy22.jpeg')} alt="Etapa de filtrado Twin-T Notch" width={960} height={640} format="webp" quality={72} loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;" />
    </div>
    
    <div class="foto-slot">
      <Image src={getImage('proy23.jpeg')} alt="Pruebas de captación de señal ECG con electrodos" width={960} height={640} format="webp" quality={72} loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;" />
    </div>

  </div>
</section>

      <!-- ── DRIVE ── -->
      <div class="drive-banner">
        <div class="drive-banner-text">
          <h3>¿Quieres ver los archivos completos?</h3>
          <p>Toda la documentación, entregables y recursos del proyecto están disponibles en Google Drive.</p>
        </div>
        <a
          href="https://drive.google.com/file/d/1vDb4aGQvWMmp3JgIMM5iy807Ou8p39Rn/view?usp=drive_link"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-drive"
        >
          ↗ Abrir en Drive
        </a>
      </div>

    </div>
  </div>

  <Footer />
</BaseLayout>
